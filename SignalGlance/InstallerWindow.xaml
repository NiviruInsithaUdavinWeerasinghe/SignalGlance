<Window x:Class="SignalGlance.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SignalGlance Setup" 
        Height="480" Width="600"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Custom CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Border" 
                                        Width="16" Height="16" 
                                        CornerRadius="3" 
                                        Background="#11FFFFFF" 
                                        BorderBrush="#33FFFFFF" 
                                        BorderThickness="1">
                                    <Path x:Name="CheckMark" 
                                          Width="10" Height="8" 
                                          SnapsToDevicePixels="True" 
                                          Stroke="#00E676" 
                                          StrokeThickness="2" 
                                          Data="M1,4 L4,7 L9,1" 
                                          Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00E676"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00E676"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ScrollBar Styles -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#44FFFFFF" CornerRadius="4" Width="6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Thumb" Property="Background" Value="#00E676"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF" Background="#FF121214" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar / Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12 21a2 2 0 1 1-4 0 2 2 0 0 1 4 0z M2.293 8.293a1 1 0 0 1 1.414 0 13.947 13.947 0 0 1 16.586 0 1 1 0 0 1 0 1.414L18.88 11.12" 
                          Fill="#00E676" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="SignalGlance Setup" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step Progress Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Border Width="22" Height="22" CornerRadius="5" Background="#00E676" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock x:Name="StepNumText" Text="1" Foreground="#121214" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Pill segments (4 pills for 4 pages) -->
                    <Border x:Name="Pill1" Width="20" Height="6" CornerRadius="3" Background="#00E676" Margin="0,0,4,0"/>
                    <Border x:Name="Pill2" Width="20" Height="6" CornerRadius="3" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,4,0"/>
                    <Border x:Name="Pill3" Width="20" Height="6" CornerRadius="3" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,4,0"/>
                    <Border x:Name="Pill4" Width="20" Height="6" CornerRadius="3" Background="Transparent" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,4,0"/>
                </StackPanel>

                <Button Grid.Column="3" HorizontalAlignment="Right" Click="CloseButton_Click" Width="24" Height="24" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" CornerRadius="4" x:Name="BtnBorder">
                                <Path Data="M 2,2 L 10,10 M 10,2 L 2,10" Stroke="#A0FFFFFF" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Wizard Pages -->
            <Grid Grid.Row="1" Margin="0,20">
                
                <!-- Page 1: Introduction -->
                <Grid x:Name="IntroPage" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Welcome to SignalGlance" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#A0FFFFFF" FontSize="13" LineHeight="20">
                        SignalGlance is a lightweight, real-time WiFi and network monitor designed for Windows.
                        <LineBreak/><LineBreak/>
                        Features:
                        <LineBreak/>
                        •  Sit in the System Tray out of your way.
                        <LineBreak/>
                        •  Display real-time statistics (Ping, Download, and Upload speeds).
                        <LineBreak/>
                        •  Alert you immediately with bottom-left slide-in notifications when connection quality changes.
                        <LineBreak/>
                        •  Track historical Wi-Fi data usage per SSID with daily &amp; monthly charts.
                        <LineBreak/>
                        •  Pin the dashboard window to the desktop so it stays open.
                    </TextBlock>
                    
                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <TextBlock Text="Installation Options:" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <CheckBox x:Name="DesktopShortcutCheckBox" IsChecked="True" Content="Create Desktop shortcut" Margin="0,0,0,6"/>
                        <CheckBox x:Name="StartupCheckBox" IsChecked="False" Content="Run SignalGlance automatically on Windows startup" Margin="0,0,0,6"/>
                    </StackPanel>
                </Grid>

                <!-- Page 2: License Agreement -->
                <Grid x:Name="LicensePage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="License Agreement" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    
                    <Border CornerRadius="6" Background="#0C0C0E" BorderBrush="#22FFFFFF" BorderThickness="1" Grid.Row="1" Margin="0,0,0,10">
                        <ScrollViewer Padding="12" VerticalScrollBarVisibility="Auto">
                            <TextBlock TextWrapping="Wrap" Foreground="#E0FFFFFF" FontSize="11.5" LineHeight="17">
                                Please review the license terms before installing SignalGlance.
                                <LineBreak/><LineBreak/>
                                1. Grant of License: You are granted a personal, non-exclusive license to use SignalGlance on compatible Windows systems.
                                <LineBreak/><LineBreak/>
                                2. Privacy: SignalGlance is committed to your privacy. All ping measurements, connection tests, and Wi-Fi data usage tracking details are performed and stored locally on your device. No personal details, SSID names, or network traffic data are ever collected, transmitted, or shared.
                                <LineBreak/><LineBreak/>
                                3. Disclaimer of Warranty: The software is provided "AS IS", without warranty of any kind, express or implied.
                            </TextBlock>
                        </ScrollViewer>
                    </Border>

                    <CheckBox Grid.Row="2" x:Name="AgreeCheckBox" Checked="AgreeCheckBox_Changed" Unchecked="AgreeCheckBox_Changed" Content="I agree to the terms and conditions" Foreground="White" FontSize="12" VerticalContentAlignment="Center"/>
                </Grid>

                <!-- Page 3: Installation Progress -->
                <Grid x:Name="ProgressPage" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Installing SignalGlance..." Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        
                        <StackPanel Grid.Row="1" Margin="10,0">
                            <StackPanel Orientation="Horizontal" x:Name="Step1" Margin="0,0,0,10">
                                <TextBlock Text="○" Foreground="#88FFFFFF" FontSize="14" Width="24" x:Name="Step1Bullet"/>
                                <TextBlock Text="Creating installation directory" Foreground="#88FFFFFF" FontSize="13" x:Name="Step1Text"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" x:Name="Step2" Margin="0,0,0,10">
                                <TextBlock Text="○" Foreground="#88FFFFFF" FontSize="14" Width="24" x:Name="Step2Bullet"/>
                                <TextBlock Text="Copying application binaries" Foreground="#88FFFFFF" FontSize="13" x:Name="Step2Text"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" x:Name="Step3" Margin="0,0,0,10">
                                <TextBlock Text="○" Foreground="#88FFFFFF" FontSize="14" Width="24" x:Name="Step3Bullet"/>
                                <TextBlock Text="Configuring Windows Startup registry" Foreground="#88FFFFFF" FontSize="13" x:Name="Step3Text"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" x:Name="Step4" Margin="0,0,0,10">
                                <TextBlock Text="○" Foreground="#88FFFFFF" FontSize="14" Width="24" x:Name="Step4Bullet"/>
                                <TextBlock Text="Creating Desktop shortcut" Foreground="#88FFFFFF" FontSize="13" x:Name="Step4Text"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2" Margin="10,0">
                            <TextBlock x:Name="ProgressStatusText" Text="Preparing installation..." Foreground="White" FontSize="12" Margin="0,0,0,8"/>
                            <ProgressBar x:Name="InstallationProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" Background="#11FFFFFF" Foreground="#00E676" BorderThickness="0">
                                <ProgressBar.Template>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Grid x:Name="TemplateRoot">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="3"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ProgressBar.Template>
                            </ProgressBar>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Page 4: Finish Screen -->
                <Grid x:Name="FinishPage" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#00E676" Width="56" Height="56" Stretch="Uniform" Margin="0,0,0,15"/>
                        <TextBlock Text="Installation Completed" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="SignalGlance has been successfully installed on your computer." Foreground="#A0FFFFFF" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <CheckBox x:Name="LaunchCheckBox" IsChecked="True" Content="Launch SignalGlance now" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Bottom Buttons / Navigation -->
            <Grid Grid.Row="2" VerticalAlignment="Bottom">
                <Button x:Name="CancelButton" Click="CloseButton_Click" Content="Cancel" HorizontalAlignment="Left" Width="80" Height="28" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1AFFFFFF" CornerRadius="4" x:Name="BtnBorder">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#2AFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="NextButton" Click="NextButton_Click" Content="Next" HorizontalAlignment="Right" Width="80" Height="28" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#00E676" CornerRadius="4" x:Name="BtnBorder">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="Black" TextBlock.FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#33FFFFFF"/>
                                    <Setter Property="TextBlock.Foreground" Value="#66FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#00C853"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
