<Window x:Class="SignalGlance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SignalGlance Dashboard" 
        Height="320" Width="480"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Custom Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" CornerRadius="6" Background="#0AFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="1" Padding="14,5">
                            <ContentPresenter x:Name="Content" TextBlock.Foreground="#88FFFFFF" TextBlock.FontSize="11" TextBlock.FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1500E676"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00E676"/>
                                <Setter TargetName="Content" Property="TextBlock.Foreground" Value="#00E676"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#8000E676"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ScrollBar Thumbs Style -->
        <Style x:Key="ScrollThumbs" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Rectangle x:Name="rect" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="Auto" Height="Auto" Fill="#22FFFFFF" RadiusX="3" RadiusY="3"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Fill" TargetName="rect" Value="#5500E676"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter Property="Fill" TargetName="rect" Value="#9900E676"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbs}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="#1CFFFFFF" Background="#FF131317" Margin="8"
            RenderOptions.ClearTypeHint="Enabled">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Tabs Bar -->
                <RowDefinition Height="*"/>    <!-- Content Panel -->
                <RowDefinition Height="Auto"/> <!-- Bottom Status -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12 21a2 2 0 1 1-4 0 2 2 0 0 1 4 0z M2.293 8.293a1 1 0 0 1 1.414 0 13.947 13.947 0 0 1 16.586 0 1 1 0 0 1 0 1.414L18.88 11.12" 
                          Fill="#00E676" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0" x:Name="HeaderStatusIcon"/>
                    <TextBlock Text="SignalGlance" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Pin Button -->
                    <Button x:Name="PinBtn" Click="PinButton_Click" ToolTip="Pin Window (Keep Open)" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,6,0" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4" x:Name="BtnBorder">
                                    <Path x:Name="PinPath" Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z" Fill="#88FFFFFF" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0"/>
                                        </Path.RenderTransform>
                                        <Path.RenderTransformOrigin>0.5,0.5</Path.RenderTransformOrigin>
                                    </Path>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseButton" Click="SettingsButton_Click" ToolTip="Close/Exit App" VerticalAlignment="Center" Width="20" Height="20" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="4" x:Name="BtnBorder">
                                    <Path x:Name="ClosePath" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Fill="#88FFFFFF" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="ClosePath" Property="Fill" Value="#33FFFFFF"/>
                                        <Setter TargetName="BtnBorder" Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Tabs Segmented Control -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <RadioButton x:Name="TabMonitor" Style="{StaticResource TabButtonStyle}" Content="Monitor" IsChecked="True" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabSpeedTest" Style="{StaticResource TabButtonStyle}" Content="Speed Test" Margin="8,0,0,0" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabWifi" Style="{StaticResource TabButtonStyle}" Content="Usage History" Margin="8,0,0,0" Checked="Tab_Checked"/>
            </StackPanel>

            <!-- Content Panel -->
            <Grid Grid.Row="2">
                
                <!-- Tab 1: Monitor Grid -->
                <Grid x:Name="MonitorGrid" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ping Stat (Top span both) -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0AFFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="M12,2A10,10,0,0,0,2,12a9.89,9.89,0,0,0,1.89,5.85L5.3,16.44A8,8,0,1,1,18.7,16.44l1.41,1.41A9.89,9.89,0,0,0,22,12,10,10,0,0,0,12,2Zm1,6V13H11V8ZM9,14H15v1H9Z" 
                                  Fill="#00E676" Width="22" Height="22" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Latency" Foreground="#88FFFFFF" FontSize="11"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,1,0,0">
                                    <TextBlock x:Name="PingVal" Text="--" Foreground="White" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text=" ms" Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Download Speed -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,4,0" Padding="12,8">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Path Data="M19 9h-4V3H9v6H5l7 7 7-7z M5 18v2h14v-2H5z" Fill="#00E676" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Download" Foreground="#88FFFFFF" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock x:Name="DownVal" Text="0.0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text=" Mbps" Foreground="#88FFFFFF" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Upload Speed -->
                    <Border Grid.Row="1" Grid.Column="1" Background="#0AFFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1" CornerRadius="8" Margin="4,0,0,0" Padding="12,8">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Path Data="M5 14h4v6h6v-6h4l-7-7-7 7z M5 3v2h14V3H5z" Fill="#00B0FF" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Upload" Foreground="#88FFFFFF" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock x:Name="UpVal" Text="0.0" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text=" Mbps" Foreground="#88FFFFFF" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tab 2: Speed Test Grid -->
                <Grid x:Name="SpeedTestGrid" Visibility="Collapsed">
                    <!-- Ready State -->
                    <Grid x:Name="SpeedTestReadyState" Visibility="Visible">
                        <Button x:Name="StartSpeedTestButton" Click="StartSpeedTestButton_Click" HorizontalAlignment="Center" VerticalAlignment="Center" Width="90" Height="90" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="Glow" Fill="#0A00E676" Stroke="#00E676" StrokeThickness="1" Margin="-4"/>
                                        <Ellipse x:Name="Circle" Fill="#11FFFFFF" Stroke="#33FFFFFF" StrokeThickness="1.5"/>
                                        <TextBlock Text="GO" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Circle" Property="Stroke" Value="#00E676"/>
                                            <Setter TargetName="Glow" Property="Fill" Value="#2200E676"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Active State (Perfectly Centered Speedometer) -->
                    <Grid x:Name="SpeedTestActiveState" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Gauge Canvas -->
                            <Canvas Width="120" Height="82" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Speedometer Arc Trace -->
                                <Path Data="M 10,75 A 50,50 0 1 1 110,75" Stroke="#14FFFFFF" StrokeThickness="4" Fill="Transparent" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                <Path Data="M 10,75 A 50,50 0 1 1 110,75" Stroke="#4400E676" StrokeThickness="4" StrokeDashArray="3 1.5" Fill="Transparent" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                
                                <!-- Speedometer Needle (Pivots perfectly around 60,75) -->
                                <Path Data="M -2,0 L 2,0 L 0,-50 Z" Fill="#00E676" x:Name="SpeedNeedle" Canvas.Left="60" Canvas.Top="75">
                                    <Path.RenderTransform>
                                        <RotateTransform x:Name="NeedleRotate" Angle="-90" CenterX="0" CenterY="0"/>
                                    </Path.RenderTransform>
                                </Path>
                                
                                <!-- Central Cap -->
                                <Ellipse Fill="#FF131317" Stroke="#00E676" StrokeThickness="2" Width="10" Height="10" Canvas.Left="55" Canvas.Top="70"/>
                            </Canvas>

                            <!-- Digital Readout (Placed below, no overlap) -->
                            <TextBlock x:Name="ActivePhaseText" Text="PING" Foreground="#88FFFFFF" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="ActiveSpeedText" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ActiveUnitText" Text="ms" Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="SpeedTestStatusText" Text="Connecting..." Foreground="#00E676" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Result State -->
                    <Grid x:Name="SpeedTestResultState" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <UniformGrid Rows="1" Columns="3" VerticalAlignment="Center">
                                <!-- Ping Result -->
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Ping" Foreground="#88FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock x:Name="ResultPingVal" Text="--" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text=" ms" Foreground="#88FFFFFF" FontSize="9" VerticalAlignment="Bottom" Margin="1,0,0,2"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Download Result -->
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Download" Foreground="#88FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock x:Name="ResultDownVal" Text="--" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text=" Mbps" Foreground="#88FFFFFF" FontSize="9" VerticalAlignment="Bottom" Margin="1,0,0,2"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Upload Result -->
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Upload" Foreground="#88FFFFFF" FontSize="10" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <TextBlock x:Name="ResultUpVal" Text="--" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text=" Mbps" Foreground="#88FFFFFF" FontSize="9" VerticalAlignment="Bottom" Margin="1,0,0,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </UniformGrid>

                            <Button Grid.Row="1" x:Name="RestartSpeedTestButton" Click="RestartSpeedTestButton_Click" Content="TEST AGAIN" HorizontalAlignment="Center" Height="26" Width="96" Margin="0,12,0,0" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#1AFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" x:Name="BtnBorder">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" TextBlock.FontSize="10" TextBlock.FontWeight="SemiBold"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#00E676"/>
                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#00E676"/>
                                                <Setter Property="TextBlock.Foreground" Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Tab 3: Wi-Fi History Grid -->
                <Grid x:Name="WifiGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Known Networks List Box -->
                    <Border Grid.Column="0" Background="#0AFFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1" CornerRadius="8" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Networks" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold" Margin="4,0,0,6"/>
                            <ListBox Grid.Row="1" x:Name="WifiNetworksList" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="WifiNetworksList_SelectionChanged" PreviewMouseWheel="ListBox_PreviewMouseWheel">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder" CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2200E676"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#10FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="ActiveDot" Width="6" Height="6" Fill="#00E676" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            <TextBlock x:Name="NameText" Text="{Binding SSID}" Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="ActiveDot" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="NameText" Property="Foreground" Value="#00E676"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Right: Usage details -->
                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header & Filters -->
                            <RowDefinition Height="*"/>    <!-- Stats view -->
                        </Grid.RowDefinitions>

                        <!-- Header and Filter Selector -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SelectedWifiNameText" Text="Select a network" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="FilterDaily" Content="Daily" IsChecked="True" Checked="Filter_Checked" Style="{StaticResource TabButtonStyle}" FontSize="9" Padding="8,3"/>
                                <RadioButton x:Name="FilterMonthly" Content="Monthly" Margin="4,0,0,0" Checked="Filter_Checked" Style="{StaticResource TabButtonStyle}" FontSize="9" Padding="8,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Usage Stats / History -->
                        <Border Grid.Row="1" Background="#0AFFFFFF" BorderBrush="#0CFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                            <Grid>
                                <!-- Empty State -->
                                <TextBlock x:Name="WifiEmptyStateText" Text="Select a Wi-Fi network to view data usage." Foreground="#55FFFFFF" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>

                                <!-- Stats State -->
                                <Grid x:Name="WifiStatsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Main number -->
                                        <RowDefinition Height="*"/>    <!-- Recent History List -->
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Big usage count -->
                                    <StackPanel Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Center">
                                        <TextBlock Text="TOTAL DATA CONSUMED" Foreground="#88FFFFFF" FontSize="9" HorizontalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="WifiTotalUsageText" Text="0.00" Foreground="#00E676" FontSize="24" FontWeight="Bold"/>
                                            <TextBlock x:Name="WifiTotalUsageUnit" Text=" MB" Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Historical Records -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Usage History" Foreground="#88FFFFFF" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <ListBox Grid.Row="1" x:Name="WifiHistoryList" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ListBox_PreviewMouseWheel">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Focusable" Value="False"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Padding" Value="0,4"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Key}" Foreground="#CCFFFFFF" FontSize="11"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

            </Grid>

            <!-- Bottom status -->
            <TextBlock Grid.Row="3" x:Name="StatusLabel" Text="Monitoring network..." Foreground="#55FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
